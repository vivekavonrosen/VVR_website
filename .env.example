# Google Tag Manager container ID.
# Create a container at https://tagmanager.google.com and paste its ID here.
# Format: GTM-XXXXXXX
# GA4 (Google Analytics) is configured *inside* GTM, so only this ID is needed on the site.
# Optional: the code already defaults to the production container (GTM-MBT56NQB).
# Set this only to override per-environment.
NEXT_PUBLIC_GTM_ID=GTM-MBT56NQB
